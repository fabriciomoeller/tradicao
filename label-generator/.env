# Configurações da Etiqueta
LABEL_WIDTH=7
LABEL_HEIGHT=3.5
LABEL_UNIT=cm

# Margens (em cm)
MARGIN_TOP=1
MARGIN_BOTTOM=1
MARGIN_LEFT=1
MARGIN_RIGHT=1

# Imagem de fundo
BACKGROUND_IMAGE="imagem/nasrudin.jpeg"
BACKGROUND_OPACITY=0.8

# Configurações de impressão
LABELS_PER_ROW=3
LABELS_PER_COLUMN=8

# Fonte do texto
FONT_SIZE=14
FONT_FAMILY=Arial
TEXT_COLOR=#000000

# Valores padrão para os tickets
DEFAULT_VALUES=5.00,10.00,20.00
DEFAULT_QUANTITIES=5,3,2
